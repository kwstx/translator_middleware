# Project Configuration
PROJECT_NAME="Agent Translator Middleware"
API_STR="/api/v1"

# Database Configuration (Docker internal)
POSTGRES_SERVER=db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=translator_db
DATABASE_URL=postgresql+asyncpg://admin:password@db:5432/translator_db

# Database Configuration (Local external)
LOCAL_DATABASE_URL=postgresql+asyncpg://admin:password@localhost:5432/translator_db

# Task queue configuration
TASK_POLL_INTERVAL_SECONDS=2
TASK_LEASE_SECONDS=60
TASK_MAX_ATTEMPTS=5
AGENT_MESSAGE_LEASE_SECONDS=60
AGENT_MESSAGE_MAX_ATTEMPTS=5

# Security & API Keys (Placeholders)
SECRET_KEY=yoursecretkeyhere
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_JWT_SECRET=4f140c9f91fa3a2cb66d9cb18ae39b6e
RATE_LIMIT_DEFAULT=10000/minute
RATE_LIMIT_ENABLED=true
UVICORN_WORKERS=2

# External API Keys
OPENAI_API_KEY=sk-placeholder
ANTHROPIC_API_KEY=placeholder
MCP_SERVER_URL=http://localhost:8080

# Redis (semantic cache)
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SEMANTIC_CACHE_TTL_SECONDS=600

# Error Tracking
SENTRY_DSN=

# Test Authentication
TEST_AUTH_TOKEN=test-staging-token-999

# Trading Template Adapters
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_SECRET=your_coinbase_secret_here

# Feed API Keys (Step 9)
X_BEARER_TOKEN=your_x_bearer_token_here
FRED_API_KEY=your_fred_api_key_here
REUTERS_APP_KEY=your_reuters_partner_key_here
