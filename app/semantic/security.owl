<?xml version="1.0"?>
<rdf:RDF xmlns="http://agent.middleware.org/security#"
     xml:base="http://agent.middleware.org/security"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://agent.middleware.org/security"/>

    <!-- Base classes -->
    <owl:Class rdf:about="http://agent.middleware.org/security#tool-invocation"/>
    <owl:Class rdf:about="http://agent.middleware.org/security#customer-entity"/>

    <!-- Customer data subclasses -->
    <owl:Class rdf:about="http://agent.middleware.org/security#customer-profile">
        <rdfs:subClassOf rdf:resource="http://agent.middleware.org/security#customer-entity"/>
    </owl:Class>
    <owl:Class rdf:about="http://agent.middleware.org/security#customer-email">
        <rdfs:subClassOf rdf:resource="http://agent.middleware.org/security#customer-profile"/>
    </owl:Class>
    <owl:Class rdf:about="http://agent.middleware.org/security#customer-phone">
        <rdfs:subClassOf rdf:resource="http://agent.middleware.org/security#customer-profile"/>
    </owl:Class>
    <owl:Class rdf:about="http://agent.middleware.org/security#customer-address">
        <rdfs:subClassOf rdf:resource="http://agent.middleware.org/security#customer-profile"/>
    </owl:Class>
</rdf:RDF>
